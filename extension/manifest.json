{
  "manifest_version": 3,
  "name": "Synthesis Alpha Intel",
  "version": "1.0",
  "description": "Extracts financial news for Synthesis Portfolio.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"]
    }
  ]
}